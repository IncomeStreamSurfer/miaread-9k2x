---
import type { LinkItem } from '../lib/links';
interface Props { link: LinkItem }
const { link } = Astro.props;
---
<a
  href={link.href}
  target={link.external ? '_blank' : undefined}
  rel={link.external ? 'noopener noreferrer' : undefined}
  data-link-key={link.key}
  class="link-btn group block w-full rounded-2xl bg-white/80 backdrop-blur border border-pink/30 hover:border-pink-deep/60 hover:bg-white transition-all duration-300 px-5 py-4 text-left shadow-sm hover:shadow-md hover:-translate-y-0.5"
>
  <div class="flex items-center gap-4">
    <span class="shrink-0 flex items-center justify-center w-11 h-11 rounded-full bg-cream-deep text-pink-deep">
      {link.icon === 'instagram' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5">
          <rect x="3" y="3" width="18" height="18" rx="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
        </svg>
      )}
      {link.icon === 'book' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5">
          <path d="M4 5a2 2 0 0 1 2-2h12v16H6a2 2 0 0 0-2 2z"/>
          <path d="M8 7h6M8 11h6"/>
        </svg>
      )}
      {link.icon === 'goodreads' && (
        <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm4.6 13.7a4.1 4.1 0 0 1-3.9 2.5 4.2 4.2 0 0 1-3.2-1.3 4.9 4.9 0 0 1-1.2-3h1.5a3.2 3.2 0 0 0 .8 2 2.8 2.8 0 0 0 2.1.9 2.6 2.6 0 0 0 2.5-1.5 6.5 6.5 0 0 0 .5-2.8v-.5a3.6 3.6 0 0 1-3.2 1.9 4 4 0 0 1-3.1-1.3 4.8 4.8 0 0 1-1.2-3.4 5 5 0 0 1 1.2-3.5A4 4 0 0 1 11.7 7a3.6 3.6 0 0 1 3.2 1.9V7.2h1.5v7.2a5.8 5.8 0 0 1-.8 3.3Zm-1.5-4.3a3.6 3.6 0 0 0 .7-2.3 3.4 3.4 0 0 0-.7-2.3 2.6 2.6 0 0 0-2-.9 2.5 2.5 0 0 0-2 .9 4.2 4.2 0 0 0 0 4.6 2.5 2.5 0 0 0 2 .9 2.5 2.5 0 0 0 2-.9Z"/>
        </svg>
      )}
      {link.icon === 'mail' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5">
          <rect x="3" y="5" width="18" height="14" rx="2"/>
          <path d="m3 7 9 6 9-6"/>
        </svg>
      )}
      {link.icon === 'club' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5">
          <circle cx="9" cy="8" r="3"/>
          <circle cx="17" cy="10" r="2.5"/>
          <path d="M3 20a6 6 0 0 1 12 0M14 20a5 5 0 0 1 8-2"/>
        </svg>
      )}
      {link.icon === 'heart' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-5 h-5">
          <path d="M12 20s-7-4.3-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.7-7 10-7 10Z"/>
        </svg>
      )}
    </span>
    <span class="flex-1 min-w-0">
      <span class="block font-display text-lg text-ink leading-tight group-hover:text-pink-deep transition-colors">{link.label}</span>
      {link.sublabel && <span class="block text-sm text-ink/60 mt-0.5 truncate">{link.sublabel}</span>}
    </span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-pink-deep/50 group-hover:translate-x-0.5 transition-transform">
      <path d="m9 6 6 6-6 6"/>
    </svg>
  </div>
</a>
